# Data files (not to be published due to SSJDA contract and personal data protection)
data/raw/
data/processed/
*.csv
*.dta
*.sav
# Synthetic data is safe to publish (no real records) and is needed to run
# the pipeline with --synthetic out of the box.
!data/synthetic/
!data/synthetic/*.csv
# Macro data (public official CPI statistics) is bundled for reproducibility.
!data/macro/
!data/macro/*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Environment variables
.env
